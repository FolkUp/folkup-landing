{
  "name": "folkup-landing",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite-ssg build && node scripts/generate-sitemap.mjs && node scripts/validate-build.mjs",
    "build:only": "vite-ssg build",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "validate": "node scripts/validate-build.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-320 --project=mobile-375 --project=mobile-390 --project=mobile-414",
    "test:e2e:prod": "BASE_URL=https://folkup.app playwright test",
    "lint": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "happy-dom": "^20.8.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-ssg": "^0.24.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  }
}
